# ─── Database ────────────────────────────────────────────────────────────────
# Option A: single connection string (used by Neon in production)
DATABASE_URL=postgresql://user:password@host:5432/env_monitoring

# Option B: individual vars (used locally)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=env_monitoring
DB_PASSWORD=your_password
DB_PORT=5432

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development   # set to "production" on Render

# ─── OpenWeatherMap ───────────────────────────────────────────────────────────
# Get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_api_key
TARGET_CITY=Bengaluru

# ─── Region ───────────────────────────────────────────────────────────────────
REGION_ID=1

# ─── Ingestor / Simulator ─────────────────────────────────────────────────────
# Must match PORT above + your WRITE_API_KEY below
SERVER_URL=http://localhost:3001/api/data

# ─── Adaptive Threshold ───────────────────────────────────────────────────────
# 0.2 = threshold is 20% above the rolling mean. Lower = more sensitive.
DEVIATION_FACTOR_DEFAULT=0.2

# ─── Security ─────────────────────────────────────────────────────────────────
# Protects POST /api/data and DELETE /api/alerts/clear.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Send as HTTP header:  X-API-Key: <your key>
# REQUIRED in production (NODE_ENV=production). Optional in development.
WRITE_API_KEY=generate_a_random_64_char_hex_string

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave blank to allow all (dev only).
# Example for Vercel: CORS_ORIGIN=https://weatherintel.vercel.app